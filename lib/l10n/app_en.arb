  "changelog226SourceParagraphs": "Fixed paragraph boundaries and first-line indentation for online chapter text",
  "changelog226OnlineFonts": "Moved interface and reader fonts to on-demand downloads to reduce the app size",
  "changelog226AiSettings": "Expanded AI reading model settings and localized service error messages",
  "changelog226SmoothChapterTurns": "Made horizontal turns between online chapters complete smoothly using warmed layouts",
  "changelog226BackgroundDownloads": "Added a shared download queue with Android progress notifications so downloads continue outside the active screen",
  "changelog226AndroidIcon": "Reduced the Android launcher symbol's visual footprint for more balanced padding",
  "changelog225UnifiedTextReader": "Unified local files and online sources on the same text pagination and rendering engine",
  "changelog225SourceChapterTurn": "Fixed horizontal cross-chapter turns rebuilding the page before the animation finished",
  "changelog225AppIcons": "Updated app icons consistently across mobile, desktop, web, and OpenHarmony",
  "changelog224SourceCatalogPaging": "Updated source support to ORSP 1.3 and fetch complete chapter catalogs using each source's declared page-size limit",
  "changelog224SourceHtmlParagraphs": "Fixed paragraph boundaries being lost when source HTML separates paragraphs with <br> elements",
  "changelog224MobileNavigation": "Reduced the mobile home floating navigation height to leave more room for content",
  "changelog221TabletBackPage": "Fixed tablet spread page-curl backs so turning the right page shows the next left page in normal reading orientation",
  "changelog220TabletSpread": "Added an optional landscape tablet spread with top information split across the left and right pages",
  "changelog220PageCurl": "Rebuilt page-curl tracking, cross-spine layering, and settling to fix jumps, tails, and incorrect overlap",
  "changelog220ReaderPerformance": "Improved TXT opening transitions, source chapter prefetching, and pagination reuse to reduce waiting",
  "changelog220NavigationThemes": "Added icon-only or labeled floating navigation and unified sorting for built-in and custom reader themes",
  "changelog220ReadingStats": "Redesigned detailed reading statistics with a consistent paper-inspired layout",
  "changelog220PageOrganization": "Reorganized page source by feature area with consistent naming and module boundaries",
  "changelog220OfficialUpdates": "Added GitHub and official-site update choices; Android can download, verify, and hand official APKs to the system installer",
  "changelog220ReleaseDistribution": "Added official-site mirrors and download statistics with stricter asset, checksum, APK version, and signing verification",
  "changelog220SourcePolicy": "Clarified third-party source responsibilities and added developer product and optional support entries",
  "changelog203DeveloperProducts": "Added settings links for 小元读书 and 小元读书社区",
  "changelog203Donation": "Added optional WeChat and Alipay donation entries with no effect on app features",
  "changelog202PaperInformation": "Embedded reader information in each paper page so it moves with slide and page-curl turns",
  "changelog202PageNumberInset": "Inset page numbers from screen edges to avoid rounded-corner clipping",
  "changelog201BackwardPageTurn": "Improved backward simulated turns with immediate mid-screen tracking and a stable binding edge during vertical hand movement",
  "changelog201SnapshotPreheat": "Preheated both adjacent pages together to reduce first backward-turn latency",
  "changelog201SourceFilters": "Added all-source and per-source discovery filters with balanced latest-book interleaving",
  "changelog120CustomFonts": "Improved custom fonts with import and management",
  "changelog120SystemBars": "Polished the status bar and reading controls",
  "changelog120BookAnimations": "Redesigned book open and close animations",
  "changelog120TabletLibrary": "Improved the tablet library layout",
  "changelog120Typography": "Improved reader layout with zero margins and more text per page",
  "changelog120VolumeKeys": "Added volume-key page turning on Android",
  "changelog120Import": "Redesigned book import with safer bottom controls",
  "changelog120Covers": "Generated simple covers for books without artwork",
  "changelog120Licenses": "Added offline open-source license viewing",
  "changelog121ContinuousScroll": "Added shared chapter-by-chapter and continuous whole-book scrolling for online sources",
  "changelog121Typography": "Fixed asymmetric Chinese text margins and aligned pagination with rendering",
  "changelog124PaperLeaf": "Added paper-bound page chrome, classic fold animation, and reader typography controls",
  "changelog122ContinuousTap": "Restored center-tap reader controls during continuous online scrolling",
  "changelog200ReaderExperience": "Upgraded top information, page numbering, and simulated page turns",
