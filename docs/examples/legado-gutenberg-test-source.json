{
  "bookSourceUrl": "https://www.gutenberg.org",
  "bookSourceName": "Project Gutenberg（公版测试）",
  "bookSourceGroup": "public-domain/test",
  "bookSourceType": 0,
  "enabled": true,
  "bookSourceComment": "Open Reading 非官方兼容测试源，仅用于 Project Gutenberg 公版内容与 Legado Lite 能力测试。",
  "searchUrl": "https://www.gutenberg.org/ebooks/search/?query={{key}}",
  "ruleSearch": {
    "bookList": "li.booklink",
    "name": ".title@text",
    "author": ".subtitle@text",
    "bookUrl": "a.link@href"
  },
  "ruleBookInfo": {
    "name": "h1@text",
    "author": "a[itemprop='creator']@text",
    "intro": "td[itemprop='description']@text",
    "coverUrl": "img.cover-art@src",
    "tocUrl": "@url"
  },
  "ruleToc": {
    "chapterList": "table.files a[type*='text/plain']",
    "chapterName": "@text",
    "chapterUrl": "@href"
  },
  "ruleContent": {
    "content": "body@text"
  }
}
